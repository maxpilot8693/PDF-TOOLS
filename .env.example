# .env.example
# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# CLOUDCONVERT_API_KEY: Required for PDF to Word and Word to PDF conversion.
# WARNING: Exposing this in VITE_ makes it a client-side secret. 
# It is used for pure SPA architecture as requested but restricts you to client-side billing safety features (like allowed domains config in CloudConvert dashboard).
VITE_CLOUDCONVERT_API_KEY=""
